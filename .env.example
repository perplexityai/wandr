# Add only the keys for providers you intend to run. `smoke.yaml` uses OpenAI
# and Perplexity; `smoke-all.yaml`, `validation.yaml`, and `wandr.yaml` use all
# six providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
EXA_API_KEY=
PARALLEL_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY=  # Supported alternative for Gemini.

# Required only for configs that use the E2B execution environment.
E2B_API_KEY=
